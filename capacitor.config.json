{
  "appId": "com.shamikhahmed.DeePonyCap",
  "appName": "DeePonyCap",
  "webDir": ".",
  "server": {
    "androidScheme": "https",
    "iosScheme": "capacitor"
  },
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": true,
    "preferredContentMode": "mobile",
    "backgroundColor": "#F0C4D8"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "backgroundColor": "#F0C4D8",
      "showSpinner": false
    }
  }
}